{
  "name": "iambacon-style-guide",
  "version": "1.4.2",
  "description": "CSS and style guide for iambacon.co.uk",
  "scripts": {
    "start": "grunt",
    "build": "npm run css:build",
    "css:build": "grunt build",
    "docs:build": "grunt deploy",
    "check": "npm run css:build && npm run docs:build && npm audit",
    "prepare": "husky install",
    "backstop:approve": "backstop approve",
    "backstop:test": "backstop test --docker",
    "backstop:init": "backstop init"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iambacon/Styles"
  },
  "author": "Colin Bacon",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@lodder/grunt-postcss": "^3.1.1",
    "autoprefixer": "^10.5.2",
    "backstopjs": "^6.3.25",
    "commitizen": "^4.3.2",
    "cssnano": "^8.0.2",
    "cz-conventional-changelog": "^3.2.0",
    "grunt": "^1.6.2",
    "grunt-bump": "^0.8.0",
    "grunt-cache-bust": "^1.7.0",
    "grunt-cli": "^1.5.0",
    "grunt-concurrent": "^3.0.0",
    "grunt-contrib-clean": "^2.0.1",
    "grunt-contrib-compress": "^2.0.0",
    "grunt-contrib-watch": "^1.1.0",
    "grunt-sass": "^4.1.0",
    "grunt-shell": "^4.0.0",
    "husky": "^7.0.4",
    "postcss": "^8.5.15",
    "prettier": "2.4.1",
    "sass": "^1.101.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "overrides": {
    "js-yaml": "^4.3.0",
    "lodash": "^4.18.1",
    "minimatch": "^3.1.5"
  },
  "browserslist": [
    "defaults"
  ]
}
